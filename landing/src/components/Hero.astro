---
import HeroScene from './HeroScene.tsx';
---

<section class="hero">
  <div class="hero-scene">
    <HeroScene client:visible />
  </div>
  <div class="container">
    <div class="hero-badge">
      <span class="hero-badge-new">New</span>
      <a href="#features" class="hero-badge-text">Chrome Extension + Side Panel</a>
    </div>
    <h1>Social Intent<br /><span class="highlight">For Sales Teams</span></h1>
    <p class="hero-sub">
      Open-source, AI-powered monitoring across 7 platforms
      for enterprise-grade lead discovery.
    </p>
    <div class="hero-ctas">
      <a class="btn btn-primary btn-lg" href="/app/register">Start for free</a>
      <a class="btn btn-outline btn-lg" href="https://github.com/rohansx/leadecho" target="_blank" rel="noreferrer">View docs</a>
    </div>
  </div>
</section>
