---
---

<section class="pricing" id="pricing">
  <div class="container">
    <div style="text-align:center;">
      <div class="section-label section-label-bracket">Pricing</div>
      <div class="section-title">Simple plans,<br />no per-seat surprises</div>
      <p class="section-sub">Or self-host for free. All AI costs go to your own API key.</p>
    </div>
    <div class="pricing-grid">

      <div class="plan">
        <div class="plan-name">Free</div>
        <div class="plan-price">$0 <small>/ mo</small></div>
        <div class="plan-desc">For trying it out</div>
        <ul class="plan-feats">
          <li>3 keywords</li>
          <li>Reddit + Hacker News</li>
          <li>50 scored mentions / mo</li>
          <li>BYOK AI</li>
          <li class="off">Chrome extension</li>
          <li class="off">Reply queue</li>
          <li class="off">UTM attribution</li>
        </ul>
        <a class="btn btn-outline" href="/app/register">Get started</a>
      </div>

      <div class="plan pop">
        <div class="pop-badge">&gt; Most Popular</div>
        <div class="plan-name">Starter</div>
        <div class="plan-price">$29 <small>/ mo</small></div>
        <div class="plan-desc">For solo founders</div>
        <ul class="plan-feats">
          <li>15 keywords</li>
          <li>All 7 platforms</li>
          <li>2,000 scored mentions / mo</li>
          <li>BYOK AI</li>
          <li>Chrome extension + side panel</li>
          <li>Reply queue + auto-posting</li>
          <li>UTM attribution</li>
          <li>Knowledge base RAG</li>
        </ul>
        <a class="btn btn-primary" href="/app/register">Start free trial</a>
      </div>

      <div class="plan">
        <div class="plan-name">Pro</div>
        <div class="plan-price">$79 <small>/ mo</small></div>
        <div class="plan-desc">For growing teams</div>
        <ul class="plan-feats">
          <li>50 keywords</li>
          <li>All 7 platforms</li>
          <li>Unlimited scored mentions</li>
          <li>BYOK AI</li>
          <li>Chrome extension + side panel</li>
          <li>Reply queue + auto-posting</li>
          <li>UTM attribution</li>
          <li>Camoufox stealth browser</li>
          <li>Slack/Discord webhooks</li>
        </ul>
        <a class="btn btn-outline" href="/app/register">Start free trial</a>
      </div>

      <div class="plan">
        <div class="plan-name">Self-host</div>
        <div class="plan-price">Free <small>forever</small></div>
        <div class="plan-desc">Your infra, your data</div>
        <ul class="plan-feats">
          <li>Unlimited everything</li>
          <li>All 7 platforms</li>
          <li>Full source code (MIT)</li>
          <li>Docker compose in 5 min</li>
          <li>No vendor lock-in</li>
          <li>Community support</li>
        </ul>
        <a class="btn btn-outline" href="https://github.com/rohansx/leadecho" target="_blank" rel="noreferrer">View on GitHub</a>
      </div>

    </div>
  </div>
</section>
