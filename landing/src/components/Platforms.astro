---

<section class="trusted">
  <div class="container">
    <div class="trusted-label">Monitored Platforms</div>
    <div class="trusted-logos">
      {platforms.map((p) => (
        <div class="trusted-logo">
          <svg viewBox="0 0 24 24" width="18" height="18" fill={p.color} class="trusted-svg">
            <path d={p.d} />
          </svg>
          <span class="trusted-name">{p.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trusted-svg {
    flex-shrink: 0;
    opacity: 0.85;
    transition: opacity 0.2s;
  }
  .trusted-logo:hover .trusted-svg {
    opacity: 1;
  }
  .trusted-name {
    color: var(--text2);
    transition: color 0.2s;
  }
  .trusted-logo:hover .trusted-name {
    color: var(--text);
  }
  [data-theme="light"] .trusted-svg[fill="#000000"] {
    fill: #111111;
  }
  [data-theme="light"] .trusted-svg[fill="#0A0A0A"] {
    fill: #111111;
  }
</style>
