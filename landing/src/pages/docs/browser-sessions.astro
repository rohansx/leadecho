  <h2>Session Management API</h2>

  <table>
    <thead>
      <tr>
        <th>Method</th>
        <th>Path</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><code>GET</code></td>
        <td><code>/api/v1/settings/sessions/&#123;platform&#125;</code></td>
        <td>Get session status (username only, no cookies)</td>
      </tr>
      <tr>
        <td><code>PUT</code></td>
        <td><code>/api/v1/settings/sessions/&#123;platform&#125;</code></td>
        <td>Store new session cookies (encrypted)</td>
      </tr>
      <tr>
        <td><code>DELETE</code></td>
        <td><code>/api/v1/settings/sessions/&#123;platform&#125;</code></td>
        <td>Remove stored session</td>
      </tr>
      <tr>
        <td><code>POST</code></td>
        <td><code>/api/v1/settings/sessions/&#123;platform&#125;/test</code></td>
        <td>Test connectivity using stored session</td>
      </tr>
    </tbody>
  </table>
